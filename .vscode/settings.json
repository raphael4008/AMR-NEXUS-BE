{
  // Tell VS Code to use the project venv — this fixes all Pyrefly / Pyright
  // "Cannot find module" errors for packages installed in the venv (pytest,
  // fastapi, sqlalchemy, pandas, etc.)
  "python.defaultInterpreterPath": "${workspaceFolder}/venv/bin/python",
  "python.pythonPath": "${workspaceFolder}/venv/bin/python",

  // Pyrefly-specific: point to the venv so it resolves installed stubs
  "pyrefly.pythonInterpreter": "${workspaceFolder}/venv/bin/python",

  // Pyright / Pylance (fallback type-checker settings)
  "python.analysis.extraPaths": [
    "${workspaceFolder}/src"
  ],
  "python.analysis.venvPath": "${workspaceFolder}",
  "python.analysis.venv": "venv"
}
